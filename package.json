{
  "name": "rateq",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:cov": "pnpm --filter @rateq/api test:cov",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @rateq/api db:generate",
    "db:migrate": "pnpm --filter @rateq/api db:migrate",
    "db:push": "pnpm --filter @rateq/api db:push",
    "db:studio": "pnpm --filter @rateq/api db:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@rateq/config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.2",
      "@types/react-dom": "^19.0.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
