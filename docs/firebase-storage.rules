rules_version = '2';

// RateQ — Firebase Storage rules
// Paste into Firebase Console → Storage → Rules → Publish
//
// Paths (from apps/web/src/lib/firebase/storage.ts):
//   users/{firebaseUid}/avatar/{file}
//   users/{firebaseUid}/company/logo/{file}
//   users/{firebaseUid}/company/cover/{file}
//   users/{firebaseUid}/company/registration/{file}
//   users/{firebaseUid}/company/establishment-card/{file}
//   users/{firebaseUid}/company/trade-license/{file}
//   users/{firebaseUid}/company/projects/{file}
//   users/{firebaseUid}/reviews/proof/{file}
//   users/{firebaseUid}/blog/cover/{file}
//
// Requires Firebase Authentication (email/Google) — uploads use request.auth.uid.

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function max10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isRegistrationDoc() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType == 'application/pdf';
    }

    // Public profile assets shown on marketing pages
    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && max10MB() && isImage();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/company/logo/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && max10MB() && isImage();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/company/cover/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && max10MB() && isImage();
      allow delete: if isOwner(userId);
    }

    // Company registration document (PDF or image)
    match /users/{userId}/company/registration/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && max10MB() && isRegistrationDoc();
      allow delete: if isOwner(userId);
    }

    // Company establishment card (PDF or image)
    match /users/{userId}/company/establishment-card/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && max10MB() && isRegistrationDoc();
      allow delete: if isOwner(userId);
    }

    // Company trade license (PDF or image)
    match /users/{userId}/company/trade-license/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && max10MB() && isRegistrationDoc();
      allow delete: if isOwner(userId);
    }

    // Company project showcase images
    match /users/{userId}/company/projects/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && max10MB() && isImage();
      allow delete: if isOwner(userId);
    }

    // Review proof attachments
    match /users/{userId}/reviews/proof/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && max10MB() && isRegistrationDoc();
      allow delete: if isOwner(userId);
    }

    // Admin blog cover images
    match /users/{userId}/blog/cover/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && max10MB() && isImage();
      allow delete: if isOwner(userId);
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
