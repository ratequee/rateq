    "expo-router": "~4.0.15",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.1",
    "i18next": "^24.2.0",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-i18next": "^15.4.0",
    "react-native": "0.76.5",
