// RateQ — PostgreSQL schema
// Modular monolith: each domain maps to a future microservice boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  COMPANY
  ADMIN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLUTION_PENDING
}

enum ReviewReplyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompanyProjectStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ModerationAction {
  AUTO_APPROVED
  QUEUED
  MANUAL_APPROVED
  MANUAL_REJECTED
  MANUAL_RESOLVE
  RESOLUTION_PROCEEDED
  RESOLUTION_WITHDRAWN
  FLAGGED
}

enum CompanyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum CompanyProfileChangeStatus {
  NONE
  PENDING
}

enum CompanyCatalogType {
  SERVICE
  ACTIVITY
}

enum InvitationType {
  COMPANY
  REVIEWER
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum ReviewReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewerInvitationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminPermission {
  STATS
  COMPANIES
  DIRECTORY
  MODERATION
  CONTENT
  INVITATIONS
  TEAM
}

enum AdminActivityEntityType {
  COMPANY_VERIFICATION
  COMPANY_PROFILE_CHANGE
  REVIEW
  REVIEW_REPORT
  REVIEWER_INVITATION_REQUEST
}

enum AdminActivityAction {
  APPROVED
  REJECTED
  REVISION_REQUESTED
  RESOLVED
  DELETED
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?  @map("display_name")
  firebaseUid  String?  @unique @map("firebase_uid")
  passwordHash String?  @map("password_hash")
  role              UserRole          @default(USER)
  adminPermissions  AdminPermission[] @default([]) @map("admin_permissions")
  phone         String?
  phoneVerified Boolean  @default(false) @map("phone_verified")
  isVerified    Boolean  @default(false) @map("is_verified")
  isActive      Boolean  @default(true) @map("is_active")
  reviewCount   Int      @default(0) @map("review_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile            UserProfile?
  reviews            Review[]
  ownedCompanies     Company[]          @relation("CompanyOwner")
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  companyPageViews   CompanyPageView[]
  sentInvitations    UserInvitation[]   @relation("InvitationSender")
  adminActivityLogs  AdminActivityLog[] @relation("AdminActivityActor")
  companyFavorites   CompanyFavorite[]
  reviewReports      ReviewReport[]     @relation("ReviewReporter")
  resolvedReports    ReviewReport[]     @relation("ReviewReportResolver")
  resolvedInvitationRequests ReviewerInvitationRequest[] @relation("InvitationRequestResolver")

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  fullName  String   @map("full_name")
  phone     String
  city      String
  country   String
  bio       String   @default("") @db.Text
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// ---------------------------------------------------------------------------
// Categories
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  nameEn    String   @unique @map("name_en")
  nameAr    String   @map("name_ar")
  slug      String   @unique
  iconUrl   String?  @map("icon_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companies     Company[]
  services      CategoryService[]
  subcategories CategorySubcategory[]

  @@map("categories")
}

model CategorySubcategory {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  nameEn     String   @map("name_en")
  nameAr     String   @map("name_ar")
  slug       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
  @@map("category_subcategories")
}

model CategoryService {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  name       String
  slug       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
  @@map("category_services")
}

// ---------------------------------------------------------------------------
// Companies
// ---------------------------------------------------------------------------

model Company {
  id                 String                    @id @default(cuid())
  ownerId            String?                   @unique @map("owner_id")
  categoryId         String?                   @map("category_id")
  categoryIds        Json?                     @map("category_ids")
  subcategoryIds     Json?                     @map("subcategory_ids")
  showVerifiedStamp  Boolean                   @default(false) @map("show_verified_stamp")
  name               String
  nameAr             String?                   @map("name_ar")
  slug               String                    @unique
  email              String?
  phone              String?
  description        String?                   @db.Text
  descriptionEn      String?                   @map("description_en") @db.Text
  descriptionAr      String?                   @map("description_ar") @db.Text
  logo               String?
  coverUrl           String?                   @map("cover_url")
  address            String?                   @db.Text
  latitude           Float?                    @map("latitude")
  longitude          Float?                    @map("longitude")
  crNumber           String?                   @map("cr_number")
  validationDate     DateTime?                 @map("validation_date")
  registrationDocUrl   String?                   @map("registration_doc_url")
  establishmentCardUrl String?                   @map("establishment_card_url")
  tradeLicenseUrl      String?                   @map("trade_license_url")
  verificationStatus   CompanyVerificationStatus @default(PENDING) @map("verification_status")
  profileChangeStatus  CompanyProfileChangeStatus @default(NONE) @map("profile_change_status")
  pendingProfileChanges Json?                    @map("pending_profile_changes")
  revisionNotes        String?                   @map("revision_notes") @db.Text
  country            String
  city               String
  websiteUrl         String?                   @map("website_url")
  whatsappNumber     String?                   @map("whatsapp_number")
  instagramUrl       String?                   @map("instagram_url")
  youtubeUrl         String?                   @map("youtube_url")
  facebookUrl        String?                   @map("facebook_url")
  linkedinUrl        String?                   @map("linkedin_url")
  twitterUrl         String?                   @map("twitter_url")
  services           Json?
  serviceIds         Json?                     @map("service_ids")
  activityIds        Json?                     @map("activity_ids")
  yearsEstablished   Int?                      @map("years_established")
  publicProjectCount Int?                      @map("public_project_count")
  privateProjectCount Int?                     @map("private_project_count")
  ratingAverage      Decimal                   @default(0) @map("rating_average") @db.Decimal(3, 2)
  reviewCount        Int                       @default(0) @map("review_count")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  owner         User?            @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviews       Review[]
  reviewReplies ReviewReply[]
  projects      CompanyProject[]
  pageViews     CompanyPageView[]
  invitations   UserInvitation[]
  favorites     CompanyFavorite[]
  invitationRequests ReviewerInvitationRequest[]

  @@index([country, city])
  @@index([categoryId])
  @@index([ratingAverage])
  @@index([name])
  @@map("companies")
}

model CompanyProject {
  id             String               @id @default(cuid())
  companyId      String               @map("company_id")
  slug           String
  title          String
  description    String?              @db.Text
  imageUrl       String               @map("image_url")
  projectUrl     String               @default("") @map("project_url")
  demoImages     Json?                @map("demo_images")
  clientName     String?              @map("client_name")
  location       String?
  projectDate    DateTime?            @map("project_date")
  serviceIds     Json?                @map("service_ids")
  customServices Json?                @map("custom_services")
  status         CompanyProjectStatus @default(PENDING)
  sortOrder      Int                  @default(0) @map("sort_order")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, slug])
  @@index([companyId, sortOrder])
  @@index([status])
  @@map("company_projects")
}

model CompanyPageView {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  visitorId String?  @map("visitor_id")
  userId    String?  @map("user_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, viewedAt])
  @@index([companyId, visitorId, viewedAt])
  @@index([userId, viewedAt])
  @@map("company_page_views")
}

model CompanyCatalogItem {
  id        String             @id @default(cuid())
  type      CompanyCatalogType
  nameEn    String             @map("name_en")
  nameAr    String             @map("name_ar")
  isActive  Boolean            @default(true) @map("is_active")
  sortOrder Int                @default(0) @map("sort_order")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  reviewServiceRatings ReviewServiceRating[]

  @@index([type, isActive, sortOrder])
  @@map("company_catalog_items")
}

model UserInvitation {
  id          String         @id @default(cuid())
  email       String
  type        InvitationType
  tokenHash   String         @unique @map("token_hash")
  invitedById String         @map("invited_by_id")
  companyId   String?        @map("company_id")
  expiresAt   DateTime       @map("expires_at")
  acceptedAt  DateTime?      @map("accepted_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  invitedBy User     @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([type, expiresAt])
  @@map("user_invitations")
}

model CompanyFavorite {
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
  @@map("company_favorites")
}

model ReviewerInvitationRequest {
  id              String                          @id @default(cuid())
  companyId       String                          @map("company_id")
  reviewerName    String                          @map("reviewer_name")
  email           String
  serviceProvided String                          @map("service_provided") @db.Text
  proofUrls       Json                            @default("[]") @map("proof_urls")
  status          ReviewerInvitationRequestStatus @default(PENDING)
  createdAt       DateTime                        @default(now()) @map("created_at")
  updatedAt       DateTime                        @updatedAt @map("updated_at")
  resolvedAt      DateTime?                       @map("resolved_at")
  resolvedById    String?                         @map("resolved_by_id")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("InvitationRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([status, createdAt])
  @@map("reviewer_invitation_requests")
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------

model Review {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  companyId         String       @map("company_id")
  rating            Int
  title             String
  content           String       @db.Text
  status            ReviewStatus @default(PENDING)
  hashedIp          String?      @map("hashed_ip")
  deviceFingerprint String?      @map("device_fingerprint")
  similarityScore   Decimal?     @map("similarity_score") @db.Decimal(5, 4)
  moderationScore   Int          @default(0) @map("moderation_score")
  resolutionWindowDays Int?      @map("resolution_window_days")
  resolutionDeadlineAt DateTime? @map("resolution_deadline_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  replies        ReviewReply[]
  moderationLogs ModerationLog[]
  attachments    ReviewAttachment[]
  serviceRatings ReviewServiceRating[]
  reports        ReviewReport[]

  @@index([companyId, status, createdAt])
  @@index([userId, createdAt])
  @@index([status, moderationScore])
  @@index([deviceFingerprint])
  @@index([hashedIp])
  @@map("reviews")
}

model ReviewAttachment {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  url       String
  fileName  String?  @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_attachments")
}

model ReviewReport {
  id           String             @id @default(cuid())
  reviewId     String             @map("review_id")
  reporterId   String             @map("reporter_id")
  reason       String?            @db.Text
  status       ReviewReportStatus @default(PENDING)
  createdAt    DateTime           @default(now()) @map("created_at")
  resolvedAt   DateTime?          @map("resolved_at")
  resolvedById String?            @map("resolved_by_id")

  review     Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter   User   @relation("ReviewReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?  @relation("ReviewReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reviewId])
  @@index([status, createdAt])
  @@map("review_reports")
}

model ReviewServiceRating {
  id                   String @id @default(cuid())
  reviewId             String @map("review_id")
  companyCatalogItemId String @map("company_catalog_item_id")
  rating               Int

  review             Review             @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  companyCatalogItem CompanyCatalogItem @relation(fields: [companyCatalogItemId], references: [id], onDelete: Cascade)

  @@unique([reviewId, companyCatalogItemId])
  @@index([companyCatalogItemId])
  @@map("review_service_ratings")
}

model ReviewReply {
  id        String            @id @default(cuid())
  reviewId  String            @map("review_id")
  companyId String            @map("company_id")
  content   String            @db.Text
  status    ReviewReplyStatus @default(PENDING)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([reviewId])
  @@index([companyId])
  @@index([status])
  @@map("review_replies")
}

// ---------------------------------------------------------------------------
// Admin activity audit
// ---------------------------------------------------------------------------

model AdminActivityLog {
  id          String                 @id @default(cuid())
  adminId     String                 @map("admin_id")
  entityType  AdminActivityEntityType @map("entity_type")
  entityId    String                 @map("entity_id")
  entityLabel String                 @map("entity_label")
  action      AdminActivityAction
  createdAt   DateTime               @default(now()) @map("created_at")

  admin User @relation("AdminActivityActor", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([adminId, createdAt])
  @@index([entityType, entityId])
  @@map("admin_activity_logs")
}

// ---------------------------------------------------------------------------
// Moderation
// ---------------------------------------------------------------------------

model ModerationLog {
  id        String           @id @default(cuid())
  reviewId  String           @map("review_id")
  reason    String
  score     Int
  action    ModerationAction
  createdAt DateTime         @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([action, createdAt])
  @@map("moderation_logs")
}

// ---------------------------------------------------------------------------
// Blog
// ---------------------------------------------------------------------------

model BlogPost {
  id          String         @id @default(cuid())
  status      BlogPostStatus @default(DRAFT)
  coverUrl    String?        @map("cover_url")
  publishedAt DateTime?      @map("published_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  translations BlogPostTranslation[]

  @@index([status, publishedAt])
  @@map("blog_posts")
}

model BlogPostTranslation {
  id              String   @id @default(cuid())
  postId          String   @map("post_id")
  locale          String
  title           String
  slug            String
  excerpt         String?  @db.Text
  content         String   @db.Text
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@unique([locale, slug])
  @@index([locale, slug])
  @@map("blog_post_translations")
}
