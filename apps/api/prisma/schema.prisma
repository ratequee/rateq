// RateQ — PostgreSQL schema
// Modular monolith: each domain maps to a future microservice boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  COMPANY
  ADMIN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLUTION_PENDING
}

enum ModerationAction {
  AUTO_APPROVED
  QUEUED
  MANUAL_APPROVED
  MANUAL_REJECTED
  MANUAL_RESOLVE
  RESOLUTION_PROCEEDED
  RESOLUTION_WITHDRAWN
  FLAGGED
}

enum CompanyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?  @map("display_name")
  firebaseUid  String?  @unique @map("firebase_uid")
  passwordHash String?  @map("password_hash")
  role          UserRole @default(USER)
  phone         String?
  phoneVerified Boolean  @default(false) @map("phone_verified")
  isVerified    Boolean  @default(false) @map("is_verified")
  isActive      Boolean  @default(true) @map("is_active")
  reviewCount   Int      @default(0) @map("review_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile            UserProfile?
  reviews            Review[]
  ownedCompanies     Company[]          @relation("CompanyOwner")
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  companyPageViews   CompanyPageView[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  fullName  String   @map("full_name")
  phone     String
  city      String
  country   String
  bio       String   @default("") @db.Text
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// ---------------------------------------------------------------------------
// Categories
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companies Company[]
  services  CategoryService[]

  @@map("categories")
}

model CategoryService {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  name       String
  slug       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category            Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reviewServiceRatings ReviewServiceRating[]

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
  @@map("category_services")
}

// ---------------------------------------------------------------------------
// Companies
// ---------------------------------------------------------------------------

model Company {
  id                 String                    @id @default(cuid())
  ownerId            String?                   @unique @map("owner_id")
  categoryId         String?                   @map("category_id")
  name               String
  slug               String                    @unique
  email              String?
  phone              String?
  description        String?                   @db.Text
  logo               String?
  coverUrl           String?                   @map("cover_url")
  address            String?                   @db.Text
  latitude           Float?                    @map("latitude")
  longitude          Float?                    @map("longitude")
  crNumber           String?                   @map("cr_number")
  validationDate     DateTime?                 @map("validation_date")
  registrationDocUrl   String?                   @map("registration_doc_url")
  establishmentCardUrl String?                   @map("establishment_card_url")
  tradeLicenseUrl      String?                   @map("trade_license_url")
  verificationStatus   CompanyVerificationStatus @default(PENDING) @map("verification_status")
  revisionNotes        String?                   @map("revision_notes") @db.Text
  country            String
  city               String
  websiteUrl         String?                   @map("website_url")
  services           Json?
  ratingAverage      Decimal                   @default(0) @map("rating_average") @db.Decimal(3, 2)
  reviewCount        Int                       @default(0) @map("review_count")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  owner         User?            @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviews       Review[]
  reviewReplies ReviewReply[]
  projects      CompanyProject[]
  pageViews     CompanyPageView[]

  @@index([country, city])
  @@index([categoryId])
  @@index([ratingAverage])
  @@index([name])
  @@map("companies")
}

model CompanyProject {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  title      String
  imageUrl   String   @map("image_url")
  projectUrl String   @default("") @map("project_url")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sortOrder])
  @@map("company_projects")
}

model CompanyPageView {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  visitorId String?  @map("visitor_id")
  userId    String?  @map("user_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, viewedAt])
  @@index([companyId, visitorId, viewedAt])
  @@index([userId, viewedAt])
  @@map("company_page_views")
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------

model Review {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  companyId         String       @map("company_id")
  rating            Int
  title             String
  content           String       @db.Text
  status            ReviewStatus @default(PENDING)
  hashedIp          String?      @map("hashed_ip")
  deviceFingerprint String?      @map("device_fingerprint")
  similarityScore   Decimal?     @map("similarity_score") @db.Decimal(5, 4)
  moderationScore   Int          @default(0) @map("moderation_score")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  replies        ReviewReply[]
  moderationLogs ModerationLog[]
  attachments    ReviewAttachment[]
  serviceRatings ReviewServiceRating[]

  @@index([companyId, status, createdAt])
  @@index([userId, createdAt])
  @@index([status, moderationScore])
  @@index([deviceFingerprint])
  @@index([hashedIp])
  @@map("reviews")
}

model ReviewAttachment {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  url       String
  fileName  String?  @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_attachments")
}

model ReviewServiceRating {
  id                String @id @default(cuid())
  reviewId          String @map("review_id")
  categoryServiceId String @map("category_service_id")
  rating            Int

  review          Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  categoryService CategoryService @relation(fields: [categoryServiceId], references: [id], onDelete: Cascade)

  @@unique([reviewId, categoryServiceId])
  @@index([categoryServiceId])
  @@map("review_service_ratings")
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  companyId String   @map("company_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([reviewId])
  @@index([companyId])
  @@map("review_replies")
}

// ---------------------------------------------------------------------------
// Moderation
// ---------------------------------------------------------------------------

model ModerationLog {
  id        String           @id @default(cuid())
  reviewId  String           @map("review_id")
  reason    String
  score     Int
  action    ModerationAction
  createdAt DateTime         @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([action, createdAt])
  @@map("moderation_logs")
}
