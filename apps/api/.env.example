# =============================================================================
# RateQ API — Environment variables
# Copy to .env and adjust for your environment.
# =============================================================================

NODE_ENV=development
PORT=4000
# Base path; Nest URI versioning adds /v1 → public routes at /api/v1/...
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://rateq:rateq_secret@localhost:5432/rateq?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
IP_HASH_SECRET=change-me-ip-hash-server-secret-min-32-chars
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Moderation (anti-abuse thresholds)
MODERATION_SCORE_THRESHOLD=5
MODERATION_NEW_ACCOUNT_DAYS=7
MODERATION_NEW_ACCOUNT_SCORE=2
MODERATION_VELOCITY_THRESHOLD=10
MODERATION_VELOCITY_WINDOW_HOURS=1
MODERATION_VELOCITY_SCORE=5
MODERATION_IP_HASH_SCORE=2
MODERATION_IP_LOOKBACK_DAYS=30
MODERATION_FINGERPRINT_SCORE=2
MODERATION_SIMILARITY_THRESHOLD=0.85
MODERATION_SIMILARITY_SCORE=3
MODERATION_SIMILARITY_LOOKBACK_DAYS=30

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
RATE_LIMIT_REVIEW_TTL=60
RATE_LIMIT_REVIEW_MAX=3

# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=RateQ <noreply@rateq.qa>
APP_URL=http://localhost:3000
AUTH_VERIFICATION_EXPIRES_HOURS=24
AUTH_PASSWORD_RESET_EXPIRES_HOURS=1
AUTH_PHONE_OTP_TTL_SECONDS=900

# Phone verification uses Firebase Phone Auth (SMS) on the client — no Twilio needed.

# Swagger
SWAGGER_ENABLED=true

# Firebase Admin (paste full service account JSON on one line)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated Firebase Auth UIDs allowed to access the admin dashboard
FIREBASE_ADMIN_UIDS=
